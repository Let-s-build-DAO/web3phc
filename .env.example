# Public site URL for canonicals, Open Graph, and JSON-LD (no trailing slash)
VITE_SITE_ORIGIN=https://web3phc.lbdao.xyz

# ─── Re:Config reward claim (frontend — all values are PUBLIC) ───
# Supabase Edge Function that adjudicates the first-solver claim
VITE_CLAIM_ENDPOINT=https://<project-ref>.supabase.co/functions/v1/claim-theme
# Supabase anon (publishable) key — safe to expose in the bundle
VITE_SUPABASE_ANON_KEY=

# ─── Firebase (X / Twitter login for Daily Drop — all values PUBLIC) ───
# Defaults are baked into src/config/firebase.js (project "web3phc"); only set these
# to point staging at a DIFFERENT Firebase project. Enable the Twitter provider under
# Authentication → Sign-in method, and add your domain to Authorized domains.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# ─── EmailJS (speaker application email notification — all values PUBLIC) ───
# Defaults are baked into src/lib/speakerSubmit.js; only set these to use a
# DIFFERENT EmailJS account/template. Recipient is set on the EmailJS template.
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
